# ─── Matiks Content OS ─── Environment Configuration ───

# Application
APP_NAME=Matiks Content OS
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true

# Database
DATABASE_URL=YOUR_DATABASE_URL_HERE
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis / Queue
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Vector Database
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=matiks-content-embeddings
WEAVIATE_URL=http://localhost:8080

# AI Providers
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4-turbo
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-opus-20240229
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GEMINI_MODEL=gemini-1.5-pro

# Voice Generation
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_DEFAULT_VOICE=rachel
ELEVENLABS_MODEL=eleven_multilingual_v2

# Video Generation
RUNWAY_API_KEY=YOUR_RUNWAY_API_KEY
PIKA_API_KEY=YOUR_PIKA_API_KEY
REPLICATE_API_TOKEN=YOUR_REPLICATE_API_TOKEN

# Social Media APIs
INSTAGRAM_ACCESS_TOKEN=YOUR_INSTAGRAM_TOKEN
INSTAGRAM_BUSINESS_ACCOUNT_ID=YOUR_ACCOUNT_ID
TIKTOK_API_KEY=YOUR_TIKTOK_API_KEY
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# Analytics
ANALYTICS_REFRESH_INTERVAL=300
RETENTION_TRACKING_ENABLED=true
HOOK_DROP_OFF_TRACKING=true

# Automation
N8N_WEBHOOK_URL=http://localhost:5678
FFMPEG_PATH=/usr/bin/ffmpeg
WHISPER_MODEL=base
